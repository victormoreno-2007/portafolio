---
import ThemeToggle from "./ThemeToggle.astro"

const navItems = [
  {
    title: "Habilidades",
    label: "habilidades",
    url: "/#habilidades",
  },
  {
    title: "Experiencia",
    label: "experiencia",
    url: "/#experiencia",
  },
  {
    title: "Proyectos",
    label: "proyectos",
    url: "/#proyectos",
  },
  {
    title: "Sobre mí",
    label: "sobre-mi",
    url: "/#sobre-mi",
  },
]
---

<header class="fixed top-0 z-10 flex items-center justify-center w-full mx-auto mt-2">
  <nav class="flex px-3 py-1 text-sm font-medium rounded-full text-gray-600 dark:text-gray-300 justify-center items-center gap-x-2">
    {
      navItems.map((link) => (
        <a
          class="relative block px-3 py-1.5 transition-all duration-300 ease-out rounded-full hover:bg-black/10 dark:hover:bg-white/10 hover:text-blue-600 dark:hover:text-cyan-400"
          aria-label={link.label}
          href={link.url}
        >
          {link.title}
        </a>
      ))
    }
    <ThemeToggle />
  </nav>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const sections = document.querySelectorAll("section")
    const navItems = document.querySelectorAll("header nav a")

    const callback = (entries: any[]) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navItems.forEach((item) => {
            if (item.getAttribute("aria-label") == entry.target.id) {
              item.classList.add("text-blue-600", "dark:text-cyan-400", "font-bold", "bg-black/5", "dark:bg-white/5")
            } else {
              item.classList.remove("text-blue-600", "dark:text-cyan-400", "font-bold", "bg-black/5", "dark:bg-white/5")
            }
          })
        }
      })
    }

    const observer = new IntersectionObserver(callback, {
      root: null,
      rootMargin: "0px",
      threshold: 0.3,
    })

    sections.forEach((section) => {
      observer.observe(section)
    })

    document.onvisibilitychange = () => {
      if (document.visibilityState === "hidden") {
        observer.disconnect()
      } else {
        sections.forEach((section) => {
          observer.observe(section)
        })
      }
    }
  })
</script>

<style>
  nav {
    animation: nav-shadown 1s linear both;
    animation-timeline: scroll();
    animation-range: 0 100px;
  }

  nav {
    @apply dark:bg-zinc-900/80 bg-white/80 backdrop-blur-md;
  }

  @keyframes nav-shadown {
    0% {
      @apply dark:bg-zinc-900/0 bg-white/0 backdrop-blur-none shadow-none;
    }
    to {
      @apply shadow-lg ring-1 ring-black/10 dark:ring-white/10;
    }
  }
</style>