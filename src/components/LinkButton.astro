---
interface Props {
  href: string;
  target?: string;
  rel?: string;
}

const { href, target = "_blank", rel = "noopener noreferrer", ...rest } = Astro.props;
---

<a
  href={href}
  target={target}
  rel={rel}
  role="link"
  class="
    inline-flex items-center justify-center gap-x-2
    px-4 py-2 text-sm font-medium
    rounded-full
    transition-all duration-300 ease-out
    group
    max-w-fit
    
    /* Estilos base (Light/Dark) */
    text-gray-800 dark:text-gray-100
    bg-white dark:bg-zinc-900/60
    border border-gray-300 dark:border-white/10
    shadow-sm backdrop-blur-sm

    /* Efectos HOVER (Tu solicitud) */
    hover:scale-105 hover:-translate-y-1
    hover:shadow-md
    hover:shadow-current/10 /* Ligera sombra del color del texto actual en hover */

    /* Colores y bordes en HOVER (Unificados con el tema azul/cian) */
    hover:bg-gray-50 dark:hover:bg-zinc-800
    hover:text-blue-700 dark:hover:text-cyan-400
    hover:border-blue-400 dark:hover:border-cyan-500/50

    /* Accesibilidad (Focus) */
    focus:outline-none focus:ring-2 focus:ring-offset-2
    focus:ring-blue-500 dark:focus:ring-cyan-500
    dark:focus:ring-offset-zinc-900
  "
  {...rest}
>
  <slot />
</a>