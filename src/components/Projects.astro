---
import GitHub from "./icons/GitHub.astro"
import Tailwind from "./icons/Tailwind.astro"
import python from "./icons/python.astro"
import React from "./icons/React.astro"
import TypeScript from "./icons/Typescript.astro"
import fastapi from "./icons/Fastapi.astro"
import Link from "./icons/Link.astro"
import LinkButton from "./LinkButton.astro"
import Html from "./icons/html.astro"
import Css from "./icons/css.astro"
import JavaScript from "./icons/javascript.astro"
import Spring from "./icons/spring.astro"
import Java from "./icons/java.astro"
import SystemIcon from "./icons/System.astro"

const TAGS = {
  REACT: {
    name: "React",
    class: "border-[#00D8FF]/40 bg-[#00D8FF]/10 text-[#00D8FF]",
    icon: React,
  },
  TAILWIND: {
    name: "Tailwind CSS",
    class: "border-[#38BDF8]/40 bg-[#38BDF8]/10 text-[#38BDF8]",
    icon: Tailwind,
  },
  TYPESCRIPT: {
    name: "TypeScript",
    class: "border-[#3178C6]/40 bg-[#3178C6]/10 text-[#3178C6]",
    icon: TypeScript,
  },
  PYTHON: {
    name: "Python",
    class: "border-[#3776AB]/40 bg-[#3776AB]/10 text-[#3776AB]",
    icon: python,
  },
  FASTAPI: {
    name: "FastAPI",
    class: "border-[#009688]/40 bg-[#009688]/10 text-[#009688]",
    icon: fastapi,
  },
  HTML: {
    name: "HTML",
    class: "border-[#E34F26]/40 bg-[#E34F26]/10 text-[#E34F26]",
    icon: Html,
  },
  CSS: {
    name: "CSS",
    class: "border-[#1572B6]/40 bg-[#1572B6]/10 text-[#1572B6]",
    icon: Css,
  },
  JAVASCRIPT: {
    name: "JavaScript",
    class: "border-[#F7DF1E]/50 bg-[#F7DF1E]/15 text-[#F7DF1E]",
    icon: JavaScript,
  },
  JAVA: {
    name: "Java",
    class: "border-[#007396]/40 bg-[#007396]/10 text-[#007396]",
    icon: Java,
  },
  SPRING: {
    name: "Spring Boot",
    class: "border-[#6DB33F]/40 bg-[#6DB33F]/10 text-[#6DB33F]",
    icon: Spring,
  },
  N8N: {
    name: "n8n",
    class: "border-[#ea4669]/40 bg-[#ea4669]/10 text-[#ea4669]",
    icon: SystemIcon, 
  },
  GEMINI: {
    name: "Google Gemini (IA)",
    class: "border-[#8E75B2]/40 bg-[#8E75B2]/10 text-[#8E75B2]",
    icon: SystemIcon,
  },
  POSTGRESQL: {
    name: "PostgreSQL",
    class: "border-[#336791]/40 bg-[#336791]/10 text-[#336791]",
    icon: SystemIcon,
  },
}

const PROJECTS = [
  {
    title: "Gestor de Reservas de Salas de Coworking",
    description: "Construir una API REST con Python que permita el registro e inicio de sesión de usuarios con autenticación, la creación y administración de salas de coworking, sistema de reservas con validaciones de horarios y la generación de reportes simples.",
    github: "https://github.com/victormoreno-2007/gestorReservas.git",
    image: "/projects/svgl.webp", 
    tags: [TAGS.PYTHON, TAGS.FASTAPI],
  },
  {
    title: "Tienda online",
    description: "Crear una aplicación web que consuma datos desde una API pública, los represente dinámicamente en el DOM, y permita a los usuarios interactuar con dichos productos a través de un sistema de carrito de compras con persistencia de datos en localStorage.",
    link: "https://project-javascript-3yyh5oqpj-victor-morenos-projects-91b4041e.vercel.app/",
    github: "https://github.com/victormoreno-2007/ProjectJavascript.git",
    image: "/projects/javascript.png",
    tags: [TAGS.HTML, TAGS.CSS, TAGS.JAVASCRIPT],
  },
  {
    title: "CrediYa - Sistema de Gestión de Préstamos y Pagos",
    description: "Aplicación desarrollada en Java para la administración integral de créditos. Implementa una arquitectura basada en capas (Dominio, Datos, Servicio y Vista) con conexión a bases de datos relacionales mediante JDBC. Permite gestionar clientes, empleados, calcular cuotas de préstamos y procesar pagos con validación de reglas de negocio.",
    github: "https://github.com/victormoreno-2007/crediya",
    image: "/projects/crediya.png",
    tags: [TAGS.JAVA],
  },
  {
    title: "Construrrenta - Plataforma Full Stack de Renta de Equipos",
    description: "Sistema integral de alquiler con control de roles (Administrador, Proveedor, Cliente). Backend desarrollado con Java y Spring Boot aplicando Arquitectura Hexagonal y seguridad basada en tokens JWT. Frontend construido con React y TypeScript, implementando gestión de estado global, carritos de reserva y paneles administrativos interactivos.",
    github: "https://github.com/victormoreno-2007/proyecto-spring-boot",
    image: "/projects/springBoot.png",
    tags: [TAGS.JAVA, TAGS.SPRING, TAGS.REACT, TAGS.CSS, TAGS.TYPESCRIPT],
  },
  {
    title: "AI Travel Copilot - Asistente de Rutas Inteligente",
    description: "Flujo de trabajo automatizado que analiza rutas geolocalizadas, consulta el clima en múltiples puntos del trayecto y utiliza agentes de IA (Google Gemini) para generar recomendaciones de seguridad vial personalizadas (moto, carro o a pie). Incluye procesamiento de datos geográficos con JavaScript y persistencia en bases de datos relacionales.",
    github: "", 
    image: "/projects/n8n.png",
    tags: [TAGS.N8N, TAGS.GEMINI, TAGS.POSTGRESQL, TAGS.JAVASCRIPT],
  },
]
---

<div class="flex flex-col gap-y-16">
  {
    PROJECTS.map(({ image, title, description, tags, link, github }) => (
      <article class="flex flex-col space-x-0 space-y-8 group md:flex-row md:space-x-8 md:space-y-0">
        <div class="w-full md:w-1/2">
          <div class="relative flex flex-col items-center gap-8 transition-all duration-500 ease-in-out transform overflow-hidden rounded-xl 
                      /* Estilos base de borde y sombra sutil (Light/Dark) */
                      border border-gray-200 dark:border-white/10 
                      shadow-xl shadow-blue-500/5 dark:shadow-cyan-500/5
                      
                      /* EFECTOS HOVER: Elevación, borde de color y resplandor intenso */
                      group-hover:-translate-y-2 
                      group-hover:shadow-2xl 
                      group-hover:shadow-blue-600/20 dark:group-hover:shadow-cyan-400/30 
                      group-hover:border-blue-500 dark:group-hover:border-cyan-5=600/50">
            <img 
              alt={title} 
              class="object-cover object-top w-full aspect-video transition duration-500 group-hover:scale-110" 
              src={image} 
              loading="lazy"
            />
          </div>
        </div>

        <div class="w-full md:w-1/2 md:max-w-lg flex flex-col justify-center">
          <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100">
            {title}
          </h3>
          
          <div class="flex flex-wrap mt-4">
            <ul class="flex flex-wrap mb-4 gap-2">
              {tags.map((tag) => (
                <li>
                  <span class={`flex gap-x-2 items-center rounded-full text-xs font-semibold py-1.5 px-3 border transition-transform hover:scale-105 ${tag.class}`}>
                    <tag.icon class="size-4" />
                    {tag.name}
                  </span>
                </li>
              ))}
            </ul>

            <div class="mt-2 text-gray-700 dark:text-gray-400 text-pretty">
              {description}
            </div>
            
            <footer class="flex flex-wrap items-end justify-start mt-6 gap-4">
              {github && (
                <LinkButton href={github}>
                  <GitHub class="size-5" />
                  Ver código
                </LinkButton>
              )}
              {link && (
                <LinkButton href={link}>
                  <Link class="size-5" />
                  Ir al sitio web
                </LinkButton>
              )}
            </footer>
          </div>
        </div>
      </article>
    ))
  }
</div>