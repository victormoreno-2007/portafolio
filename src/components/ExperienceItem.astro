---
import LinkInline from "./LinkInline.astro"

interface Props {
  title: string
  company: string
  description: string
  link?: string
  linkName?: string
  date: string
}

const { title, company, description, link, linkName = "Saber más", date } = Astro.props
---

<div
  class="relative mx-12 pb-12 grid before:absolute before:left-[-35px] before:block before:h-full before:border-l-2 before:border-black/20 dark:before:border-white/15 before:content-[''] md:grid-cols-5 md:gap-10 md:space-x-4]"
>
  <div class="relative pb-12 md:col-span-2">
    <div class="sticky top-0">
      <span class="absolute -left-[43px] flex items-center justify-center">
        <span class="pulse-ring"></span>
        <span class="pulse-dot"></span>
      </span>
      <h3 class="text-xl font-bold text-blue-600 dark:text-cyan-400">{title}</h3>
      <h4 class="font-semibold text-xl text-gray-800 dark:text-gray-200 mt-1">{company}</h4>
      <time class="p-0 m-0 text-sm text-gray-600/80 dark:text-white/60">{date}</time>
    </div>
  </div>
  <div class="relative flex flex-col gap-2 pb-4 text-gray-600 dark:text-gray-300 md:col-span-3 text-pretty">
    {description}
    {
      link && (
        <LinkInline href={link}>
          {linkName}{" "}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 icon icon-tabler icon-tabler-chevron-right transition-transform group-hover:translate-x-1"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            fill="none"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <>
              <path stroke="none" d="M0 0h24v24H0z" fill="none" />
              <path d="M9 6l6 6l-6 6" />
            </>
          </svg>
        </LinkInline>
      )
    }
  </div>
</div>

<style>
  .pulse-dot {
    position: relative;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: #2563eb; /* blue-600 */
    box-shadow: 0 0 8px 2px rgba(37, 99, 235, 0.7);
    z-index: 1;
  }

  :global(.dark) .pulse-dot {
    background-color: #22d3ee; /* cyan-400 */
    box-shadow: 0 0 8px 2px rgba(34, 211, 238, 0.7);
  }

  .pulse-ring {
    position: absolute;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background-color: rgba(37, 99, 235, 0.25);
    animation: radar-ping 2s ease-out infinite;
  }

  :global(.dark) .pulse-ring {
    background-color: rgba(34, 211, 238, 0.2);
  }

  @keyframes radar-ping {
    0%   { transform: scale(0.5); opacity: 1; }
    80%  { transform: scale(2.2); opacity: 0; }
    100% { transform: scale(2.2); opacity: 0; }
  }
</style>