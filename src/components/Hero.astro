---
const personalImageAlt = "Victor Moreno";
import Badge from "@/components/Badge.astro";
import LinkedInIcon from "@/components/icons/LinkedIn.astro";
import MailIcon from "@/components/icons/Mail.astro";
import SocialPill from "@/components/SocialPill.astro";
import GitHub from "./icons/GitHub.astro";
import { getLangFromUrl, useTranslations } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
// extraer texto de subtitulo
const heroText = t("hero.subtitle");
const heroBold = t("hero.subtitle_bold");
---

<section
  class="flex flex-col md:flex-row items-center md:items-start gap-10 max-w-5xl mx-auto mt-10 px-4"
>
  <div class="flex flex-col items-center md:items-start">
    <div class="relative size-48 md:size-56">
      <div class="ring-wrapper">
        <img
          class="absolute inset-[4px] rounded-full object-cover w-[calc(100%-8px)] h-[calc(100%-8px)]"
          src="/foto.png"
          alt={personalImageAlt}
        />
      </div>
    </div>
    <div class="mt-4">
      <Badge>{t("hero.badge")}</Badge>
    </div>
  </div>

  <div
    class="flex flex-col items-center md:items-start text-center md:text-left max-w-xl"
  >
    <h1
      class="text-4xl font-bold tracking-tight text-black sm:text-5xl dark:text-white"
    >
      {t("hero.title").split("Victor")[0]} <span class="animated-gradient-text">Victor</span>
    </h1>

    
    <p 
      class="mt-6 text-lg sm:text-xl text-gray-800 dark:text-gray-300 [&>strong]:font-semibold leading-relaxed [&>strong]:text-blue-600 dark:[&>strong]:text-cyan-400"
      data-hero-text={heroText}
      data-hero-bold={heroBold}
    >
      <span id="typewriter-text"></span><span id="typewriter-cursor" class="typewriter-cursor">|</span>
    </p>

    <nav class="flex flex-wrap gap-4 mt-8">
      <SocialPill
        href="https://mail.google.com/mail/?view=cm&to=vmsamur2007@gmail.com"
        target="_blank"
        rel="noopener noreferrer"
      >
        <MailIcon class="size-5" />
        {t("hero.contact")}
      </SocialPill>

      <SocialPill
        href="https://www.linkedin.com/in/victor-moreno-931b42386/"
        target="_blank"
        rel="noopener noreferrer"
      >
        <LinkedInIcon class="size-5" />
        {t("hero.linkedin")}
      </SocialPill>

      <SocialPill
        href="https://github.com/victormoreno-2007"
        target="_blank"
        rel="noopener noreferrer"
      >
        <GitHub class="size-5" />
        {t("hero.github")}
      </SocialPill>
    </nav>
  </div>
</section>
<script>
  function initTypewriter() {
    const el = document.getElementById('typewriter-text');
    const cursor = document.getElementById('typewriter-cursor');
    const wrapper = el?.closest('p');
    
    if (!el || !cursor || !wrapper) return;

    const heroText = wrapper.getAttribute('data-hero-text');
    const heroBold = wrapper.getAttribute('data-hero-bold');
    if (!heroText || !heroBold) return;

    if ((window as any).typewriterInterval) clearInterval((window as any).typewriterInterval);

    const boldStart = heroText.indexOf(heroBold);
    const boldEnd   = boldStart + heroBold.length;

    let i = 0;
    el.innerHTML = '';
    cursor.style.display = 'inline-block';

    (window as any).typewriterInterval = setInterval(() => {
      i++;
      const current = heroText.slice(0, i);
      const before = current.slice(0, boldStart);
      const bold   = current.slice(boldStart, Math.min(i, boldEnd));
      const after  = current.slice(Math.min(i, boldEnd));

      if (i <= boldStart) {
        el.innerHTML = current;
      } else if (i <= boldEnd) {
        el.innerHTML = before + '<strong class="font-semibold text-blue-600 dark:text-cyan-400">' + bold + '</strong>';
      } else {
        el.innerHTML = before + '<strong class="font-semibold text-blue-600 dark:text-cyan-400">' + heroText.slice(boldStart, boldEnd) + '</strong>' + after;
      }

      if (i >= heroText.length) {
        clearInterval((window as any).typewriterInterval);
        cursor.style.display = 'none'; 
      }
    }, 18); 
  }

  document.addEventListener('astro:page-load', initTypewriter);
</script>
<style>
  .animated-gradient-text {
    background: linear-gradient(90deg, #3b82f6, #8b5cf6, #06b6d4, #3b82f6);
    background-size: 200% auto;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: gradient-move 3s linear infinite;
  }

  @keyframes gradient-move {
    0% {
      background-position: 0% center;
    }
    100% {
      background-position: 200% center;
    }
  }
  .ring-wrapper {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  padding: 4px;
  background: linear-gradient(135deg, #3b82f6, #8b5cf6, #06b6d4, #3b82f6);
  background-size: 300% 300%;
  animation: ring-rotate 3s linear infinite;
  position: relative;
}

.ring-wrapper::before {
  content: '';
  position: absolute;
  inset: 4px;
  border-radius: 50%;
  background: white;
  z-index: 0;
}

:global(.dark) .ring-wrapper::before {
  background: #0f172a;
}

.ring-wrapper img {
  position: relative;
  z-index: 1;
}

@keyframes ring-rotate {
  0%   { background-position: 0% 50%; }
  50%  { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}
.typewriter-cursor {
  display: inline-block;
  width: 2px;
  background-color: currentColor;
  margin-left: 2px;
  animation: blink 0.8s step-end infinite;
  font-weight: 100;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0; }
}
</style>
